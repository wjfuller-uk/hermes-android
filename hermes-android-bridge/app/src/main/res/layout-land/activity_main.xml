<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_circuit_pattern"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HERMES BRIDGE"
            android:textSize="24sp"
            android:textColor="#ED7931"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v0.5.0"
            android:textSize="12sp"
            android:textColor="#666666"
            android:fontFamily="monospace" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#ED7931"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="13sp"
                android:textColor="#ED7931"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/indicatorA11y"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  a11y"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvA11yStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="active"
                    android:textSize="13sp"
                    android:textColor="#4CAF50"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/indicatorServer"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  server"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvServerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8765"
                    android:textSize="13sp"
                    android:textColor="#4CAF50"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/indicatorRelay"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  relay"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvRelayAddr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="#4CAF50"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/indicatorAuth"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  auth"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvAuthCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="------"
                    android:textSize="13sp"
                    android:textColor="#4CAF50"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="13sp"
                android:textColor="#ED7931"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Accessibility Service"
                    android:textSize="13sp"
                    android:textColor="#CCCCCC"
                    android:fontFamily="monospace" />

                <Switch
                    android:id="@+id/switchAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:track="@drawable/bg_switch_track"
                    android:thumb="@drawable/bg_switch_thumb" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Status Overlay"
                    android:textSize="13sp"
                    android:textColor="#CCCCCC"
                    android:fontFamily="monospace" />

                <Switch
                    android:id="@+id/switchOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:track="@drawable/bg_switch_track"
                    android:thumb="@drawable/bg_switch_thumb" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Screen Recording Granted"
                    android:textSize="13sp"
                    android:textColor="#CCCCCC"
                    android:fontFamily="monospace" />

                <Switch
                    android:id="@+id/switchScreenRecord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:track="@drawable/bg_switch_track"
                    android:thumb="@drawable/bg_switch_thumb" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pairing Code"
                android:textSize="13sp"
                android:textColor="#ED7931"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvPairingCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="------"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="#4CAF50"
                    android:letterSpacing="0.3" />

                <Button
                    android:id="@+id/btnRegenerate"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Refresh"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_button_orange"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap code to copy. Send to Hermes, connect my phone, code is..."
                android:textSize="11sp"
                android:textColor="#666666"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect to Server"
                android:textSize="13sp"
                android:textColor="#ED7931"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etServerUrl"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="server-ip:8766"
                android:inputType="textUri"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:textColor="#CCCCCC"
                android:textColorHint="#444444"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_input_dark"
                android:layout_marginBottom="8dp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvRelayStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not connected"
                android:textSize="12sp"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="CONNECT"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="monospace"
                android:background="@drawable/bg_button_orange"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⏏ DISCONNECT"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:background="@drawable/bg_button_disconnect"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:textColor="#444444"
        android:gravity="center_horizontal" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:textSize="0sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvScreenRecordStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:textSize="0sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:visibility="gone" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:visibility="gone" />

    <Button
        android:id="@+id/btnScreenRecord"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSetupCommand"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text=""
        android:visibility="gone" />

</LinearLayout>
</ScrollView>
